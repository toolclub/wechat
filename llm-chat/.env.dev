# Cookie 配置（开发环境不要求 HTTPS）
COOKIE_SECURE=false

# CORS（开发环境）
CORS_ALLOWED_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost"]
FRONTEND_URL=http://localhost

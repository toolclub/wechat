# ============================================================
# ChatFlow 开发环境覆盖配置（MacBook）
# 只含与 .env 不同的值，启动时与 .env 合并使用
# ============================================================

APP_VERSION=1.0.8

# MacBook 数据目录
SECRET_DIR=${HOME}/chatflow-data/secret
QDRANT_DATA_DIR=${HOME}/chatflow-data/qdrant
QDRANT_PORT=6333
POSTGRES_DATA_DIR=${HOME}/chatflow-data/postgres
POSTGRES_PORT=5432
REDIS_DATA_DIR=${HOME}/chatflow-data/redis
REDIS_PORT=6379
QUANT_CACHE_DATA_DIR=${HOME}/chatflow-data/quant_cache
BACKEND_LOG_HOST_DIR=./logs

# ── JWT 配置 ─────────────────────────────────────────────────────
JWT_SECRET_KEY=ENC(gAAAAABp-PYdxOBZSCHkYwNPcLVqXcrBrYZXGNfNWAhLiM__XPPorpXnHy6gjagxWtFuEPBs-8HNclZi-akw2t54lVmfU3bbcYzpZ8dN61WW72stYojidFNA-iv3m0pzMCKV-mHdIO9t)
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ── OAuth 配置（开发环境）────────────────────────────────────────
# Google OAuth
OAUTH_GOOGLE_CLIENT_ID=ENC(gAAAAABp-PYda9kr-hbNbeHL8fwzl4s2nZTZ03-pLC67bG0NbZuzsgbMA0zokkPU9YN0tnOep0e-saBP0kvQsdsA4Urv62AY5EzfrP1XD8X_gLjeJZKQCHzgZzypPV5_S2DbAVK8cMxXy9YOrAiopKyxx4ftDCyXmxa1SybLEh8lrNMdWdLY16k=)

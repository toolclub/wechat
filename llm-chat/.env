# ============================================================
# ChatFlow 配置
# ============================================================

# ── 镜像版本控制 ─────────────────────────────────────────────
APP_VERSION=1.0.8

# ── LLM 服务 ─────────────────────────────────────────────────
LLM_BASE_URL=https://api.minimaxi.com/v1
API_KEY=ENC(gAAAAABp01yitZyVdZtpPhnm0eedI7OBcenugdLGUMI1bCwMANgGoMudPcMigGjQIu1p9lbqXuFJZiRr_kqxgqpt8sdwcaeqSMv_JT0qv9ZW-4F0-XhXOWLV1zzNU3HJ2-IP4QlAXRu1jqmQoRfHFJxS4TI1FFvAxNFmJPm1W5EhlQ_qIdb4g-cAc4jMNHLrin7GjFjvM8yvDaj_vPwkrTZ0A-wkT8gMW9BTWVKC54Iy_TVhFxJS1Ic=)
EMBEDDING_BASE_URL=https://ai.gitee.com/v1
EMBEDDING_API_KEY=ENC(gAAAAABp06bjUYPK0-sfX3MFOu5L2X_Zsvc6DrLMZ13RJ6-1L23vkO-yg2Dtly-B-6PkFIkxaS5n_Psg7p0uQVMiCF0DnPn_6P8HVPjUd45ahoSo0Ktd54kjg0TtuxFt9pZq7M-r_t6T)

# ── 模型 ─────────────────────────────────────────────────────
CHAT_MODEL=MiniMax-M2.7-highspeed
SUMMARY_MODEL=MiniMax-M2.7-highspeed
EMBEDDING_MODEL=bge-m3

# ── 路由 Agent ────────────────────────────────────────────────
ROUTER_ENABLED=true
ROUTER_MODEL=MiniMax-M2.7-highspeed
SEARCH_MODEL=MiniMax-M2.7-highspeed
ROUTE_MODEL_MAP={"code":"MiniMax-M2.7-highspeed","search":"MiniMax-M2.7-highspeed","chat":"MiniMax-M2.7-highspeed","search_code":"MiniMax-M2.7-highspeed"}

# ── 上下文窗口 ────────────────────────────────────────────────
CHAT_NUM_CTX=8192
SUMMARY_NUM_CTX=4096
FETCH_WEBPAGE_MAX_DISPLAY=500

# ── 记忆参数 ──────────────────────────────────────────────────
SHORT_TERM_MAX_TURNS=10
SHORT_TERM_FORGET_TURNS=2
COMPRESS_TRIGGER=8
MAX_SUMMARY_LENGTH=500

# ── 长期记忆（Qdrant）────────────────────────────────────────
LONGTERM_MEMORY_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=llm_chat_memories
EMBEDDING_DIM=1024
LONGTERM_TOP_K=3
LONGTERM_SCORE_THRESHOLD=0.5
SUMMARY_RELEVANCE_THRESHOLD=0.4

# ── 语义缓存（Redis Search）──────────────────────────────────
SEMANTIC_CACHE_ENABLED=true
REDIS_URL=redis://redis:6379
SEMANTIC_CACHE_INDEX=semantic_cache
SEMANTIC_CACHE_THRESHOLD=0.85
SEMANTIC_CACHE_NAMESPACE_MODE=user
SEMANTIC_CACHE_SEARCH_TTL_HOURS=2

# ── 数据库（PostgreSQL）──────────────────────────────────────
POSTGRES_DB=chatflow
POSTGRES_USER=chatflow
POSTGRES_PASSWORD=chatflow123
DATABASE_URL=ENC(gAAAAABp01yicMWlVeIs6DOtFpCOPCgEXrmXYAwAMP7FrbXDZ8wyUnz7L3fjWvs3QrU3dsHzurQ3CJKlOyn_yErbfD79MFmfV88cn3XK1X-nPz0kYrEOnkIskAFyHimPYWVnIiD6OLbfu526P8b8o6p-3iQZWn4Fjw==)

# ── 后端服务 ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_DIR=/var/log/chatflow
CONVERSATIONS_DIR=/app/conversations

# ── Docker 宿主机数据目录 & 端口 ─────────────────────────────
SECRET_DIR=D:/opt/secret
QDRANT_DATA_DIR=D:/docker/qdrant_storage
QDRANT_PORT=6333
POSTGRES_DATA_DIR=D:/docker/postgres_data
POSTGRES_PORT=5432
REDIS_DATA_DIR=D:/docker/redis_data
REDIS_PORT=6379
BACKEND_LOG_HOST_DIR=./logs

# ── MCP 服务器 ────────────────────────────────────────────────
# MCP_SERVERS={"filesystem":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","./data"],"transport":"stdio"}}


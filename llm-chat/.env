# ── 镜像版本控制 ─────────────────────────────────────────────
APP_VERSION=1.0.8

# ── LLM 服务 ─────────────────────────────────────────────────
LLM_BASE_URL=https://api.minimaxi.com/v1
API_KEY=ENC(gAAAAABp9ORvESixHu2nPR_3ESdmM7r_7o0CfMbgX4LNyc_bBcrUeWXm5WTEBDUE3N3xaJjHXaxgmRSKwmsndrUc7VjN3scBzlOOG-91rLoOLRvrTkD9iuFhJZ3cr7r_yV9I_AE7sFA4Py3uX3IvYa4-wVGfObUg0j_R664h6bldn8rC-WFD-iYSTltSl7kZ2OcnfsYcmBeuzX24sOksIhJmF6VyWonbMXnG8x9zVDrWkbpuhBQ_hZ8=)
EMBEDDING_BASE_URL=https://ai.gitee.com/v1
EMBEDDING_API_KEY=ENC(gAAAAABp9ORvwAXEZYBOUPobMl2A-UEx9Ja87zppj_vP5VS2-ccwpPfPBa17IqQ-OYyRwrl0NzbaOK0N2vlXoOwfZwtIPAsVuMdSG9tJ8L-jzGqeKWYLgujn9m5CHZqjc4FOFc1aldsx)

# ── 模型 ─────────────────────────────────────────────────────
CHAT_MODEL=MiniMax-M2.7-highspeed
SUMMARY_MODEL=MiniMax-M2.7-highspeed
EMBEDDING_MODEL=Qwen3-Embedding-0.6B
EMBEDDING_FALLBACK_MODELS=["Qwen3-Embedding-8B","Qwen3-Embedding-4B","jina-embeddings-v4","Youtu-Embedding"]

# ── 路由 Agent ────────────────────────────────────────────────
ROUTER_ENABLED=true
ROUTER_MODEL=MiniMax-M2.7-highspeed
SEARCH_MODEL=MiniMax-M2.7-highspeed
ROUTE_MODEL_MAP={"code":"MiniMax-M2.7-highspeed","search":"MiniMax-M2.7-highspeed","chat":"MiniMax-M2.7-highspeed","search_code":"MiniMax-M2.7-highspeed"}

# ── 上下文窗口 ────────────────────────────────────────────────
CHAT_NUM_CTX=8192
SUMMARY_NUM_CTX=4096
FETCH_WEBPAGE_MAX_DISPLAY=500

# ── 记忆参数 ──────────────────────────────────────────────────
SHORT_TERM_MAX_TURNS=10
SHORT_TERM_FORGET_TURNS=2
COMPRESS_TRIGGER=8
MAX_SUMMARY_LENGTH=500

# ── 长期记忆（Qdrant）────────────────────────────────────────
LONGTERM_MEMORY_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=llm_chat_memories
EMBEDDING_DIM=1024
LONGTERM_TOP_K=3
LONGTERM_SCORE_THRESHOLD=0.5
SUMMARY_RELEVANCE_THRESHOLD=0.4

# ── 语义缓存（Redis Search）──────────────────────────────────
SEMANTIC_CACHE_ENABLED=false
REDIS_URL=redis://redis:6379
SEMANTIC_CACHE_INDEX=semantic_cache
SEMANTIC_CACHE_THRESHOLD=0.85
SEMANTIC_CACHE_NAMESPACE_MODE=user
SEMANTIC_CACHE_SEARCH_TTL_HOURS=2

# ── 数据库（PostgreSQL）──────────────────────────────────────
POSTGRES_DB=chatflow
POSTGRES_USER=chatflow
POSTGRES_PASSWORD=chatflow123
DATABASE_URL=ENC(gAAAAABp9ORvFnZOZx72L_VOgLRN_i0_ugT4qflPHmk8XOf0JNIPmZkQnbiMHoO-hJw8V7Tz6RXjm-9EquutKcdsUILjXfgaCuZIIUj0M7oOf0Xa8-Ep9z5YWHHaeprkvqvnHxNiX73yxP4l-lKYKXgXYUu8Fy5zeQ==)

# ── 后端服务 ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_DIR=/var/log/chatflow
CONVERSATIONS_DIR=/app/conversations

# ── Docker 宿主机数据目录 & 端口 ─────────────────────────────
SECRET_DIR=D:/opt/secret
QDRANT_DATA_DIR=D:/docker/qdrant_storage
QDRANT_PORT=6333
POSTGRES_DATA_DIR=D:/docker/postgres_data
POSTGRES_PORT=5432
REDIS_DATA_DIR=D:/docker/redis_data
REDIS_PORT=6379
BACKEND_LOG_HOST_DIR=./logs


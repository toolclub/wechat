# ============================================================
# ChatFlow 配置
# ============================================================

# ── 镜像版本控制 ─────────────────────────────────────────────
APP_VERSION=1.0.8

# ── LLM 服务 ─────────────────────────────────────────────────
LLM_BASE_URL=https://api.minimaxi.com/v1
API_KEY=ENC(gAAAAABp0eBA3IEtMx41rZNzJDMQmNRSDSR6sziOXFk8FSp_3N8jC-cX3QmFTHiFgyOP_ujGg6Ma2Lhtziv2fv-o6D5MMBgwoYKTlPIzH-nLbbjIlmQjM5YWEWRgu4FAEr1_pijiDwLDw5sYZOqe993cyd5RtKxIGkpIaIxGHEcpj2YBjerMFLrXOcIXJBksi1MpZpiJwWY7P3TEf4DhWMMFI_6lYX3JCwMK56zIPWuZqIl8xuysnW0=)
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1

# ── 模型 ─────────────────────────────────────────────────────
CHAT_MODEL=MiniMax-M2.5
SUMMARY_MODEL=MiniMax-M2.5
EMBEDDING_MODEL=bge-m3

# ── 路由 Agent ────────────────────────────────────────────────
ROUTER_ENABLED=true
ROUTER_MODEL=MiniMax-M2.5
SEARCH_MODEL=MiniMax-M2.5
ROUTE_MODEL_MAP={"code":"MiniMax-M2.5","search":"MiniMax-M2.5","chat":"MiniMax-M2.5","search_code":"MiniMax-M2.5"}

# ── 上下文窗口 ────────────────────────────────────────────────
CHAT_NUM_CTX=8192
SUMMARY_NUM_CTX=4096
FETCH_WEBPAGE_MAX_DISPLAY=500

# ── 记忆参数 ──────────────────────────────────────────────────
SHORT_TERM_MAX_TURNS=10
SHORT_TERM_FORGET_TURNS=2
COMPRESS_TRIGGER=8
MAX_SUMMARY_LENGTH=500

# ── 长期记忆（Qdrant）────────────────────────────────────────
LONGTERM_MEMORY_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=llm_chat_memories
EMBEDDING_DIM=1024
LONGTERM_TOP_K=3
LONGTERM_SCORE_THRESHOLD=0.5
SUMMARY_RELEVANCE_THRESHOLD=0.4

# ── 语义缓存（Redis Search）──────────────────────────────────
SEMANTIC_CACHE_ENABLED=true
REDIS_URL=redis://redis:6379
SEMANTIC_CACHE_INDEX=semantic_cache
SEMANTIC_CACHE_THRESHOLD=0.85
SEMANTIC_CACHE_NAMESPACE_MODE=user
SEMANTIC_CACHE_SEARCH_TTL_HOURS=2

# ── 数据库（PostgreSQL）──────────────────────────────────────
POSTGRES_DB=chatflow
POSTGRES_USER=chatflow
POSTGRES_PASSWORD=chatflow123
DATABASE_URL=ENC(gAAAAABp0eBAhVN7w5hBc44P13ZzS-ro6ys4cHGYwew-5KzuCNE6YA6-4-kAj4KjqXqRi1ll-a7PtNoQUpcS1Dq9yo45nVtX1sNaDr3woNTWmOWI1ET2gUQE-Y_YcSs5aFBEcJqJ_Xf7MuQD9xWB2AdpZVsc2ULx7g==)

# ── 后端服务 ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_DIR=/var/log/chatflow
CONVERSATIONS_DIR=/app/conversations

# ── Docker 宿主机数据目录 & 端口 ─────────────────────────────
SECRET_DIR=D:/opt/secret
QDRANT_DATA_DIR=D:/docker/qdrant_storage
QDRANT_PORT=6333
POSTGRES_DATA_DIR=D:/docker/postgres_data
POSTGRES_PORT=5432
REDIS_DATA_DIR=D:/docker/redis_data
REDIS_PORT=6379
BACKEND_LOG_HOST_DIR=./logs

# ── MCP 服务器 ────────────────────────────────────────────────

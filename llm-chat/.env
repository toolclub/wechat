SANDBOX_CLEANUP_HOURS=12

# MiniMax 文生图
IMAGE_GEN_ENABLED=true
IMAGE_GEN_BASE_URL=https://api.minimaxi.com/v1
IMAGE_GEN_API_KEY=ENC(gAAAAABp9ORv8UpsDM1L5a1mtf-ZeP655avSrX2_QCrWiMaWtzkcA-qVujSYzlOZufv9vl2_oSREzjPVmR3tE76isr7K6QSjBIX3V1Hr_vWB3488qV_u_lZaEOLJGICxiWH86IATth-IfGcN5U7tj79spJXe5VStmzjResOqQoUDLvTZ94nzNgR_wpc49D1hdVYKCzEkAtirXVWeQPrVzAk-2JsArXFAwBQUNJXYP9l05Kg331ntsk4=)
IMAGE_GEN_MODEL=image-01

# ── 量化模块（A 股选股） ─────────────────────────────────────
QUANT_ENABLED=true
# akshare 排第一：免 token 免积分，HTTP 并发 16，A 股全市场 ~2-3 分钟预热
# tushare 第二：积分 ≥2000 自动启用按日 bulk（30s 极速档）；120 积分时只能走 ts_code 单股
# baostock 兜底：免 token 但慢且易卡死，只在前两者都失败时使用
QUANT_PROVIDER_ORDER=["akshare","tushare","baostock","akshare_us"]
QUANT_BARS_CONCURRENCY=16
QUANT_DEFAULT_TOP_N=30
QUANT_FIRST_PASS_KEEP=200
QUANT_HTTP_TIMEOUT=20
QUANT_CACHE_DIR=/app/.quant_cache
# 分布式部署时：只让一个容器/Worker 设 primary，其余设 secondary 即跳过预热
QUANT_WARMER_ROLE=primary
# tushare bulk-by-date 的并发线程数（pro.daily 限频通常 500/min，8 线程安全）
QUANT_TUSHARE_BULK_WORKERS=8

# Tushare：100 积分仅可用 stock_basic；积分够后自动启用日线/估值快照/指数成分
TUSHARE_TOKEN=ENC(gAAAAABp-0ycG_yMeaI6_k0kUZVyzCmVurt9tYQnCWEwPYvSg_r-vbKHZcHx9l7kxiYDAXcv3X2yflzvuuatsLf1YpeXU669zViqYtINmDwrmxnZxJ0-lA7FLPOz1hiOb-ukpS6Kbdu5ZB4kHQQKKPce7HoMJ1xNoQ==)
# BaoStock：免 token，主源
BAOSTOCK_ENABLED=true

# ── JWT 配置 ─────────────────────────────────────────────────────
JWT_SECRET_KEY=ENC(gAAAAABp-PYdJsfW892Mym6xGr6aJcrzYpedfFTCgb3cpi_uvNNvo88TezWp2EhIGEQWIfzit-1-uISCVTZS2405KuEc2Xh4_ykmyQ7mK9KLqukC8CKkvM07TjTkMx0xESSpKtQYNyIM)

# ============================================================
# ChatFlow 生产覆盖配置（Mac Mini 云端）
# 只含与 .env 不同的值，启动时与 .env 合并使用
# ENC() 密文全在 .env 里，这里不重复
# ============================================================

APP_VERSION=1.0.8

# Mac Mini M4（10 核）留 2 核给 OS+服务，设 4 worker
GUNICORN_WORKERS=4

# MacBook 数据目录（$HOME 由 Docker Compose 从 shell 环境展开，无需写绝对路径）
SECRET_DIR=${HOME}/chatflow-data/secret
QDRANT_DATA_DIR=${HOME}/chatflow-data/qdrant
QDRANT_PORT=6333
POSTGRES_DATA_DIR=${HOME}/chatflow-data/postgres
POSTGRES_PORT=5432
REDIS_DATA_DIR=${HOME}/chatflow-data/redis
REDIS_PORT=6379
BACKEND_LOG_HOST_DIR=${HOME}/chatflow-data/logs
QUANT_CACHE_DATA_DIR=${HOME}/chatflow-data/quant_cache

# ── JWT 配置 ─────────────────────────────────────────────────────
JWT_SECRET_KEY=ENC(gAAAAABp-PYd5qzmrOMzuWZFYqVoYPSyQlKmgK4OVhPff7owJglqI_nNcs9sU20zttwjfVQjFXylNAWwOt4FHd56x74hmm1SrAhJ6UY-ghuKYaewAwDyjG1AgmoQQ3zPD8CqU4lU62oL)
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ── OAuth 配置（生产环境）────────────────────────────────────────
# Google OAuth（与开发共用）
OAUTH_GOOGLE_CLIENT_ID=ENC(gAAAAABp-PYdxP_b0EevmrR17NZWYTytpOJ0dKpz0ETKLklJmhNZzzN45yRHhu8i9Vsj-Cf4Plo8Tg6IWL0oI-sBkS-IQ5HODW_uRRKpKBgFsspMfBbXCNdhWBLU7zYNSPGEknclg2Qhee8voM1BgLGaM2A6DFJL54zJwK2_4DzlzuyJ45ScPOc=)
OAUTH_GOOGLE_CLIENT_SECRET=ENC(gAAAAABp-PYd3qHpGzpABKfoMUahLgUOf7nL5WDgyHe_PGJ0VRIDdKkDweY_FpCY_r3NIEfB6TwOIvXa1Jz_JMPEMlw1xQZ71ZtjFQVuQGujel0DFyHmzTYUibd_UfTzk1YrrOLAztcs)
OAUTH_GOOGLE_REDIRECT_URI=https://www.chatflow-live.com/api/auth/oauth/google/callback

# GitHub OAuth（生产）
OAUTH_GITHUB_CLIENT_ID=ENC(gAAAAABp-PYd7-g8hOr_OrQyQ6auvFyCsxLj_g2gL97lP4wfJ4rv_G3nLjc64pRmCWNE92yZbTskyjohC5U7GtnSVIkZiuDvrU2kxrn5kmszAq_be4x3X4g=)
OAUTH_GITHUB_CLIENT_SECRET=ENC(gAAAAABp-PYdDQe1NSFSxdsKH7KICHQmDhHv-M3UkKeYw35RgOE9sd6hITJoviNYcgThvFoOz3l31neLDAQ08bqUMb-ur-n_lg0NzTDm99woyLqRnoBy-jrEvIBZitKk2GUJbKTcNcNr)

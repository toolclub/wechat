# Cookie 配置（生产环境要求 HTTPS）
COOKIE_SECURE=true

# CORS（生产环境）
CORS_ALLOWED_ORIGINS=["https://www.chatflow-live.com"]
FRONTEND_URL=https://www.chatflow-live.com
